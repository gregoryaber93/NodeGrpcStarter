{
  "name": "order-service",
  "version": "1.0.0",
  "description": "Order Service with gRPC",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "proto:generate": "grpc_tools_node_protoc --plugin=protoc-gen-ts=.\\node_modules\\.bin\\protoc-gen-ts.cmd --ts_out=grpc_js:src/generated --js_out=import_style=commonjs,binary:src/generated --grpc_out=grpc_js:src/generated proto/order.proto"
  },
  "keywords": ["grpc", "microservices", "order"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grpc/grpc-js": "^1.9.14",
    "@grpc/proto-loader": "^0.7.10",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "grpc-tools": "^1.12.4",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
